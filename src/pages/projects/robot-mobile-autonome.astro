---
import Layout from '../../layouts/Layout.astro';
import personalData from '../../data/personal.json';
import projectsFile from '../../data/projects.json';

const project = projectsFile.items[0];
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const title = `${project.title} | ${personalData.name}`;
const description = project.description;
---

<Layout title={title} description={description}>
  <main id="main-content" class="project-page">
    <section class="project-hero">
      <div class="project-container">
        <a href={`${base}#projects`} class="back-link">Retour aux projets</a>
        <p class="eyebrow">Projets</p>
        <h1>{project.title}</h1>
        <p class="project-lead">{project.description}</p>
        {(project as any).highlights?.length > 0 && (
          <ul class="project-bullets">
            {(project as any).highlights.map((highlight: string) => <li>{highlight}</li>)}
          </ul>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .project-page {
    min-height: 100vh;
    color: var(--text);
    background:
      radial-gradient(circle at 20% 15%, rgba(56, 189, 248, 0.16), transparent 32%),
      linear-gradient(180deg, rgba(2, 6, 23, 0.98), rgba(15, 23, 42, 0.95));
  }

  .project-hero {
    padding: 8rem 1rem 5rem;
  }

  .project-container {
    max-width: 860px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 2rem;
    color: #93c5fd;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
  }

  .back-link:hover {
    color: #bfdbfe;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: #38bdf8;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 780px;
    margin: 0;
    color: #f8fafc;
    font-size: clamp(2.4rem, 6vw, 4.8rem);
    font-weight: 900;
    line-height: 0.98;
  }

  .project-lead {
    max-width: 760px;
    margin: 1.5rem 0 0;
    color: #cbd5e1;
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .project-bullets {
    display: grid;
    gap: 0.8rem;
    max-width: 760px;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .project-bullets li {
    position: relative;
    padding-left: 1.2rem;
    color: #cbd5e1;
    font-size: 1rem;
    line-height: 1.6;
  }

  .project-bullets li::before {
    content: '';
    position: absolute;
    top: 0.68em;
    left: 0;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #34d399;
  }

  :global([data-theme='light']) .project-page {
    background:
      radial-gradient(circle at 20% 15%, rgba(14, 165, 233, 0.12), transparent 32%),
      #f8fafc;
  }

  :global([data-theme='light']) h1 {
    color: #0f172a;
  }

  :global([data-theme='light']) .project-lead,
  :global([data-theme='light']) .project-bullets li {
    color: #475569;
  }
</style>
