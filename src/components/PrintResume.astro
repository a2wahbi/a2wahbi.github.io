---
import personal from '../data/personal.json';
import skillsData from '../data/skills.json';
import projectsFile from '../data/projects.json';
import resumeData from '../data/resume.json';
import certificationsData from '../data/certifications.json';

const skillCategories = skillsData.categories as Array<{ title: string; text?: string; skills: Array<{ name: string }> }>;
const resumeProjects = projectsFile.items.filter((p) => (p as any).resume);
const certifications = certificationsData.slice(0, 3);
---

<div class="print-only" id="resume-print">

  <header class="resume-header">
    <div class="header-left">
      <h1 class="resume-name">{personal.name}</h1>
      <p class="resume-title">{personal.title}</p>
    </div>
    <div class="header-right">
      <div>{personal.email}{personal.phone && ` · ${personal.phone}`}</div>
      <div>{personal.location}</div>
      <div>linkedin.com/in/{personal.linkedin} · github.com/{personal.github}</div>
    </div>
  </header>

  <hr class="header-rule" />

  <section class="resume-section">
    <h2 class="section-title">Profil</h2>
    <p class="body-text">{personal.bio}</p>
  </section>

  <section class="resume-section">
    <h2 class="section-title">Compétences</h2>
    <div class="skills-grid">
      {skillCategories.map(category => (
        <div class="skill-row">
          <span class="skill-items">{category.text ?? `${category.title} : ${category.skills.map(s => s.name).join(', ')}`}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="resume-section">
    <h2 class="section-title">Expériences professionnelles</h2>
    <div class="resume-experience-list">
      {resumeData.experiences.map((experience) => (
        <article class="resume-experience-item">
          <div class="resume-experience-header">
            <span class="resume-experience-title">{experience.title}</span>
            <span class="resume-experience-period">{experience.period}</span>
          </div>
          <p class="resume-experience-company">{experience.company}</p>
          {experience.description && <p class="project-desc">{experience.description}</p>}
          {experience.bullets && (
            <ul class="resume-bullets">
              {experience.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="resume-section">
    <h2 class="section-title">Projets</h2>
    <div class="projects-list">
      {resumeProjects.map(project => project && (
        <div class="project-item">
          <div class="project-header">
            <span class="project-title">{project.title}</span>
          </div>
          <p class="project-desc">{project.description}</p>
          {(project as any).highlights?.length > 0 && (
            <ul class="resume-bullets">
              {(project as any).highlights.map((highlight: string) => <li>{highlight}</li>)}
            </ul>
          )}
        </div>
      ))}
    </div>
  </section>

  <div class="resume-footer-row">
    <section class="resume-section">
      <h2 class="section-title">Formation</h2>
      <div class="compact-list">
        {resumeData.education.map((item) => (
          <p class="body-text">
            <strong>{item.title}</strong><br />
            {item.school}<br />
            {item.period}
          </p>
        ))}
      </div>
    </section>

    <section class="resume-section">
      <h2 class="section-title">Langues</h2>
      <p class="body-text">{resumeData.languages.join(' · ')}</p>
      <h2 class="section-title section-title-inline">Certifications</h2>
      <p class="body-text">
        {certifications.map((cert) => `${cert.name} - ${cert.issuer}`).join(' · ')}
      </p>
      <h2 class="section-title section-title-inline">Centres d’intérêt</h2>
      <p class="body-text">{resumeData.interests.join(' · ')}</p>
    </section>
  </div>

</div>

<style>
  #resume-print {
    font-family: 'Inter', 'Calibri', Arial, sans-serif;
    font-size: 10.5pt;
    line-height: 1.45;
    color: #000;
    background: #fff;
    max-width: 100%;
  }

  .resume-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 6px;
  }

  .header-left {
    flex: 1;
  }

  .resume-name {
    font-size: 22pt;
    font-weight: 700;
    color: #000;
    line-height: 1.1;
    margin: 0 0 3px 0;
    letter-spacing: -0.02em;
  }

  .resume-title {
    font-size: 11pt;
    color: #111;
    margin: 0;
    font-weight: 400;
  }

  .header-right {
    text-align: right;
    font-size: 9.5pt;
    color: #111;
    line-height: 1.7;
    padding-top: 4px;
  }

  .header-rule {
    border: none;
    border-top: 2px solid #000;
    margin: 6px 0;
  }

  .resume-section {
    margin-bottom: 9px;
  }

  h2.section-title, .section-title {
    font-size: 10pt;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #000 !important;
    text-shadow: 0px 1px 0px rgba(0, 0, 0, 0.8) !important;
    border-bottom: 2.5px solid #000 !important;
    padding-bottom: 2px;
    margin: 0 0 5px 0;
  }

  .body-text {
    margin: 0;
    font-size: 10pt;
    color: #000;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    gap: 2px 0;
  }

  .skill-row {
    font-size: 9.5pt;
    line-height: 1.55;
  }

  .skill-items {
    color: #111;
  }

  .resume-experience-list {
    display: grid;
    gap: 5px;
  }

  .resume-experience-item {
    page-break-inside: avoid;
  }

  .resume-experience-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .resume-experience-title {
    font-weight: 600;
    font-size: 10pt;
    color: #000;
  }

  .resume-experience-period {
    flex: 0 0 auto;
    color: #222;
    font-size: 9.5pt;
    text-align: right;
  }

  .resume-experience-company {
    margin: 1px 0 0 0;
    color: #222;
    font-size: 9.5pt;
    font-style: italic;
  }

  /* Projects */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .project-item {
    page-break-inside: avoid;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .project-title {
    flex: 1 1 auto;
    min-width: 0;
    font-weight: 600;
    font-size: 10pt;
    color: #000;
    white-space: normal;
  }

  .project-tags {
    flex: 0 0 auto;
    max-width: 46%;
    font-size: 8.5pt;
    color: #222;
    text-align: right;
    white-space: nowrap;
  }

  .project-desc {
    margin: 1px 0 0 0;
    font-size: 9pt;
    color: #111;
    padding-left: 10px;
    line-height: 1.4;
  }

  .resume-bullets {
    margin: 1px 0 0 0;
    padding-left: 18px;
    font-size: 9pt;
    color: #111;
    line-height: 1.35;
  }

  .compact-list {
    display: grid;
    gap: 5px;
  }

  /* Education + Volunteer side by side */
  .resume-footer-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 24px;
  }

  .section-title-inline {
    margin-top: 8px !important;
  }
</style>
