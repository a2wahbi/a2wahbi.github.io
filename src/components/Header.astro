  .dock-link::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(14, 165, 233, 0.08), rgba(99, 102, 241, 0.04)),
      linear-gradient(180deg, transparent 0 44%, rgba(125, 211, 252, 0.08) 44% 45%, transparent 45% 100%);
    opacity: 0;
    transition: opacity 0.22s ease;
    pointer-events: none;
  }

  .dock-link:hover,
  .dock-link:focus-visible {
    width: min(16.5rem, calc(100vw - 1rem));
    border-color: rgba(14, 165, 233, 0.42);
    box-shadow: 0 20px 42px rgba(2, 6, 23, 0.34), 0 0 0 1px rgba(14, 165, 233, 0.08);
    z-index: 2;
  }

  .dock-link:hover::after,
  .dock-link:focus-visible::after {
    opacity: 1;
  }

  .dock-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .dock-icon {
