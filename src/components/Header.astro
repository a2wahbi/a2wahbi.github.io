  }

  .overlay-ext-icon {
    width: 11px;
    height: 11px;
    opacity: 0.6;
  }

  .social-dock {
    position: fixed;
    left: 0;
    top: clamp(7rem, 32vh, 18rem);
    z-index: 45;
    display: none;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
    width: 16.5rem;
    pointer-events: none;
