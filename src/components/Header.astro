    border-color: rgba(15, 23, 42, 0.08);
    background: rgba(241, 245, 249, 0.88);
  }

  :global([data-theme='light']) .dock-label {
    color: #0f172a;
  }

  :global([data-theme='light']) .dock-desc {
    color: #64748b;
  }

  #overlay-menu .overlay-inner {
    padding: 1rem 6vw 3rem;
  }

  .nav-link.active {
    color: var(--text);
  }
  .nav-link.active::after {
    width: 100%;
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .nav-link {
      padding-bottom: 0px;
    }

    header .container .gap-6 {
      gap: 1rem !important;
    }
  }
</style>

<script>
  const html = document.documentElement;
  const checkbox = document.getElementById('theme-checkbox') as HTMLInputElement;

  function applyTheme(theme: string) {
    const metaTheme = document.getElementById('meta-theme-color') as HTMLMetaElement | null;
    if (theme === 'light') {
      html.setAttribute('data-theme', 'light');
      checkbox.checked = true;
      if (metaTheme) metaTheme.setAttribute('content', '#f8fafc');
    } else {
      html.removeAttribute('data-theme');
      checkbox.checked = false;
      if (metaTheme) metaTheme.setAttribute('content', '#020617');
    }
  }

  const THEME_KEY = document.documentElement.dataset.themeKey || 'portfolio-theme';
  applyTheme(localStorage.getItem(THEME_KEY) || 'dark');

  checkbox.addEventListener('change', () => {
    const next = checkbox.checked ? 'light' : 'dark';
    localStorage.setItem(THEME_KEY, next);
    applyTheme(next);
  });

  const overlay = document.getElementById('overlay-menu')!;
  const openBtn = document.getElementById('menu-open-btn')!;
  const closeBtn = document.getElementById('menu-close-btn')!;

  function openMenu() {
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openBtn.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);

  overlay.querySelectorAll('.overlay-link, .overlay-quick-link').forEach((a) => {
    a.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  // rootMargin shrinks the detection zone to the middle 5% of the viewport height.
  // A section is only "active" when it dominates the visible area, not just when any pixel enters view.
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((l) => l.classList.remove('active'));
          document.querySelector(`.nav-link[href="#${entry.target.id}"]`)?.classList.add('active');
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px' }
  );

  sections.forEach((s) => io.observe(s));
</script>
