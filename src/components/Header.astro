  .dock-link {
    position: relative;
    width: 3.15rem;
    min-height: 3.15rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-left: 0;
    border-radius: 0 0.82rem 0.82rem 0;
    color: #cbd5e1;
    text-decoration: none;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.92), rgba(2, 6, 23, 0.9)) padding-box,
      linear-gradient(135deg, rgba(99, 102, 241, 0.34), rgba(14, 165, 233, 0.28)) border-box;
    box-shadow: 0 16px 34px rgba(2, 6, 23, 0.24);
    pointer-events: auto;
    overflow: hidden;
    transition:
      width 0.32s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      background 0.22s ease;
