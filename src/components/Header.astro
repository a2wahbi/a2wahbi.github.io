  :global([data-theme='light']) .primary-nav {
    background: transparent;
    box-shadow: none;
  }

  :global([data-theme='light']) .nav-link-sm {
    color: #475569;
    background: transparent;
    box-shadow: none;
  }

  :global([data-theme='light']) .nav-link-sm:hover {
    color: #1e293b;
    background: #f1f5f9;
    box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.04);
  }

  :global([data-theme='light']) .site-header .nav-link.active {
    color: #1e293b;
    background: #e2e8f0;
    box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
