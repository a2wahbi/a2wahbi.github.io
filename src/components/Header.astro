---
import personalData from '../data/personal.json';
import menu from '../data/menu.json';
import siteData from '../data/site.json';

const { sections } = menu;
const headerSectionOrder = ['#about', '#expertise', '#skills', '#projects', '#certifications', '#contact'];
const headerSections = headerSectionOrder
  .map((href) => sections.find((section) => section.href === href))
  .filter(Boolean) as typeof sections;

const externalIconByKey: Record<string, string> = {
  github: 'simple-icons:github',
  linkedin: 'simple-icons:linkedin',
  email: 'lucide:mail',
  blog: 'lucide:file-text',
  phone: 'lucide:phone',
};

// Build external nav links from site.json definitions, skipping any whose personal.json key is empty.
// This lets site authors add potential platforms to navExternal without requiring all fields be filled.
const external = siteData.navExternal
  .map((item) => {
    const value = (personalData as unknown as Record<string, string>)[item.personalKey] ?? '';
    if (!value) return null;
    return {
      label: item.label,
      desc: item.desc,
      url: item.urlTemplate.replace('{value}', value),
      icon: externalIconByKey[item.personalKey] ?? 'lucide:external-link',
    };
  })
  .filter(Boolean) as { label: string; desc: string; url: string; icon: string }[];
---

<header class="site-header fixed top-0 left-0 right-0 z-50 glass-nav">
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="header-row flex items-center justify-between h-16">
      <a href="#home" class="brand-link shrink-0" aria-label={`${personalData.name} — retour à l’accueil`}>
        <span class="brand-mark" aria-hidden="true">
          <span class="brand-pin brand-pin-a"></span>
          <span class="brand-pin brand-pin-b"></span>
          <span class="brand-pulse"></span>
        </span>
        <span class="brand-copy">
          <span class="brand-name">{personalData.name}</span>
          <span class="brand-role">{personalData.heroRole}</span>
        </span>
      </a>

      <div class="primary-nav hidden xl:flex items-center gap-6" aria-label="Navigation principale">
        {
          headerSections.map((item) => (
            <a href={item.href} class="nav-link nav-link-sm">
              {item.shortLabel}
            </a>
          ))
        }
      </div>

      <div class="header-actions flex items-center gap-3">
        <label class="switch" aria-label="Basculer entre thème clair et thème sombre" title="Mode clair / sombre">
          <span class="sun"
            ><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
              ><g fill="#918155"
                ><circle r="5" cy="12" cx="12"></circle><path
                  d="m21 13h-1a1 1 0 0 1 0-2h1a1 1 0 0 1 0 2zm-17 0h-1a1 1 0 0 1 0-2h1a1 1 0 0 1 0 2zm13.66-5.66a1 1 0 0 1 -.66-.29 1 1 0 0 1 0-1.41l.71-.71a1 1 0 1 1 1.41 1.41l-.71.71a1 1 0 0 1 -.75.29zm-12.02 12.02a1 1 0 0 1 -.71-.29 1 1 0 0 1 0-1.41l.71-.66a1 1 0 0 1 1.41 1.41l-.71.71a1 1 0 0 1 -.7.24zm6.36-14.36a1 1 0 0 1 -1-1v-1a1 1 0 0 1 2 0v1a1 1 0 0 1 -1 1zm0 17a1 1 0 0 1 -1-1v-1a1 1 0 0 1 2 0v1a1 1 0 0 1 -1 1zm-5.66-14.66a1 1 0 0 1 -.7-.29l-.71-.71a1 1 0 0 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41 1 1 0 0 1 -.71.29zm12.02 12.02a1 1 0 0 1 -.7-.29l-.66-.71a1 1 0 0 1 1.36-1.36l.71.71a1 1 0 0 1 0 1.41 1 1 0 0 1 -.71.24z"
                ></path></g
              ></svg
            ></span
          >
          <span class="moon"
            ><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512"
              ><path
                d="m223.5 32c-123.5 0-223.5 100.3-223.5 224s100 224 223.5 224c60.6 0 115.5-24.2 155.8-63.4 5-4.9 6.3-12.5 3.1-18.7s-10.1-9.7-17-8.5c-9.8 1.7-19.8 2.6-30.1 2.6-96.9 0-175.5-78.8-175.5-176 0-65.8 36-123.1 89.3-153.3 6.1-3.5 9.2-10.5 7.7-17.3s-7.3-11.9-14.3-12.5c-6.3-.5-12.6-.8-19-.8z"
              ></path></svg
            ></span
          >
          <input type="checkbox" class="input" id="theme-checkbox" />
          <span class="slider"></span>
        </label>

        <a href="#contact" class="cta-btn hidden sm:inline-flex">Me contacter</a>
        <button id="menu-open-btn" class="hamburger-btn" aria-label="Ouvrir le menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>

  </nav>
</header>

{
  external.length > 0 && (
    <aside class="social-dock" aria-label="Liens rapides">
      {external.map((link) => (
        <a href={link.url} target="_blank" rel="noopener" class="dock-link" aria-label={`${link.label} — ${link.desc}`}>
          <span class="dock-icon" aria-hidden="true">
            <iconify-icon icon={link.icon} width="19" height="19" />
          </span>
          <span class="dock-copy">
            <span class="dock-label">{link.label}</span>
            <span class="dock-desc">{link.desc}</span>
          </span>
        </a>
      ))}
    </aside>
  )
}

<div
  id="overlay-menu"
  class="overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation du site"
  aria-hidden="true"
>
  <button id="menu-close-btn" class="overlay-close" aria-label="Fermer le menu">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>

  <div class="overlay-circuit" aria-hidden="true"></div>

  <div class="overlay-inner">
    <p class="overlay-eyebrow">Navigation</p>
    <nav class="overlay-nav">
      {
        headerSections.map((item, i) => (
          <a href={item.href} class="overlay-link" style={`--i: ${i};`}>
            <span class="overlay-num">0{i + 1}</span>
            <span class="overlay-link-body">
              <span class="overlay-link-label">{item.label}</span>
              <span class="overlay-link-desc">{item.desc}</span>
            </span>
            <svg
              class="overlay-arrow"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"
              />
            </svg>
          </a>
        ))
      }
    </nav>

    <div class="overlay-bottom">
      <p class="overlay-bottom-label">Liens rapides</p>
      {
        external.map((link) => (
          <a href={link.url} target="_blank" rel="noopener" class="overlay-quick-link">
            {link.label}
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="overlay-ext-icon"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
          </a>
        ))
      }
    </div>
  </div>
</div>

<style>
  .site-header {
    isolation: isolate;
  }

  .header-row {
    gap: 1rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--text);
    text-decoration: none;
    min-width: 0;
  }

  .brand-mark {
    position: relative;
    width: 2rem;
    height: 2rem;
    border: 1px solid rgba(99, 102, 241, 0.36);
    border-radius: 0.45rem;
    background:
      linear-gradient(90deg, transparent 49%, rgba(99, 102, 241, 0.18) 50%, transparent 51%),
      linear-gradient(0deg, transparent 49%, rgba(14, 165, 233, 0.16) 50%, transparent 51%),
      var(--bg-card);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.03), 0 0 18px rgba(14, 165, 233, 0.1);
    overflow: hidden;
    flex-shrink: 0;
  }

  .brand-mark::before,
  .brand-mark::after,
  .brand-pin {
    content: '';
    position: absolute;
    background: var(--neon);
    opacity: 0.85;
  }

  .brand-mark::before {
    left: 0.38rem;
    right: 0.38rem;
    top: 0.58rem;
    height: 1px;
  }

  .brand-mark::after {
    left: 0.58rem;
    top: 0.58rem;
    bottom: 0.48rem;
    width: 1px;
  }

  .brand-pin {
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    box-shadow: 0 0 10px rgba(14, 165, 233, 0.65);
  }

  .brand-pin-a {
    right: 0.38rem;
    top: 0.42rem;
  }

  .brand-pin-b {
    left: 0.42rem;
    bottom: 0.38rem;
  }

  .brand-pulse {
    position: absolute;
    right: 0.44rem;
    bottom: 0.48rem;
    width: 0.5rem;
    height: 0.5rem;
    border: 1px solid rgba(14, 165, 233, 0.8);
    border-radius: 999px;
    animation: brand-pulse 2.8s ease-in-out infinite;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
    min-width: 0;
  }

  .brand-name {
    font-size: clamp(0.95rem, 1.3vw, 1.08rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.05;
    color: var(--text);
    white-space: nowrap;
  }

  .brand-role {
    display: none;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--text-dim);
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .brand-role {
      display: inline;
    }
  }

  @keyframes brand-pulse {
    0%,
    100% {
      opacity: 0.35;
      transform: scale(0.82);
    }
    50% {
      opacity: 1;
      transform: scale(1.15);
    }
  }

  .cta-btn {
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.45rem 1.05rem;
    border-radius: 0.55rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0;
    border: 1px solid rgba(99, 102, 241, 0.42);
    color: var(--text);
    background:
      linear-gradient(var(--bg-nav), var(--bg-nav)) padding-box,
      linear-gradient(135deg, rgba(99, 102, 241, 0.7), rgba(14, 165, 233, 0.62)) border-box;
    white-space: nowrap;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s ease;
  }
  .cta-btn:hover {
    transform: translateY(-1px);
    border-color: rgba(14, 165, 233, 0.7);
    background:
      linear-gradient(rgba(99, 102, 241, 0.12), rgba(14, 165, 233, 0.08)) padding-box,
      linear-gradient(135deg, rgba(99, 102, 241, 0.9), rgba(14, 165, 233, 0.9)) border-box;
  }
  .cta-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .switch {
    position: relative;
    display: inline-block;
    width: 3.5rem;
    height: 2rem;
    flex-shrink: 0;
    cursor: pointer;
    transition:
      filter 500ms ease-in-out,
      transform 500ms ease-in-out;
    filter: saturate(1.08) brightness(1.08);
  }
  .switch:hover,
  .switch:focus-within {
    filter: saturate(1.5) brightness(1.5);
  }
  .switch:focus-within .slider {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }
  .slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      linear-gradient(var(--bg-card), var(--bg-card)) padding-box,
      linear-gradient(135deg, rgba(99, 102, 241, 0.56), rgba(14, 165, 233, 0.42)) border-box;
    border: 1px solid transparent;
    transition: 0.4s;
    border-radius: 30px;
  }
  .slider:before {
    position: absolute;
    content: '';
    height: 1.38rem;
    width: 1.38rem;
    left: 0.25rem;
    bottom: 0.25rem;
    background: linear-gradient(135deg, #e2e8f0, #94a3b8);
    transition: 0.4s;
    border-radius: 50%;
    box-shadow: 0 3px 12px rgba(2, 6, 23, 0.28);
  }
  .switch .sun svg {
    position: absolute;
    top: 0.43rem;
    left: 1.95rem;
    z-index: 1;
    width: 1.08rem;
    height: 1.08rem;
    animation: sw-rotate 30s linear infinite;
    will-change: transform;
  }
  .switch .moon svg {
    fill: var(--text-muted);
    position: absolute;
    top: 0.41rem;
    left: 0.45rem;
    z-index: 1;
    width: 1.08rem;
    height: 1.08rem;
    animation: sw-tilt 5s linear infinite;
    will-change: transform;
  }
  @keyframes sw-rotate {
    0% {
      transform: rotate(0);
    }
    100% {
      transform: rotate(360deg);
    }
  }
  @keyframes sw-tilt {
    0% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(-10deg);
    }
    75% {
      transform: rotate(10deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }
  .switch .sun {
    display: block;
  }
  .switch .moon {
    display: none;
  }
  .switch:has(.input:checked) .sun {
    display: none;
  }
  .switch:has(.input:checked) .moon {
    display: block;
  }

  .input:checked + .slider {
    background:
      linear-gradient(var(--bg-card), var(--bg-card)) padding-box,
      linear-gradient(135deg, rgba(14, 165, 233, 0.7), rgba(99, 102, 241, 0.66)) border-box;
  }
  .input:focus + .slider {
    box-shadow: 0 0 1px var(--bg-card);
  }
  .input:checked + .slider:before {
    transform: translateX(1.5rem);
    background: linear-gradient(135deg, #60a5fa, #6366f1);
  }
  @media (max-width: 767px) {
    .switch {
      width: 3.35rem;
      height: 1.9rem;
    }
  }

  .hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .hamburger-btn:hover {
    background: rgba(99, 102, 241, 0.1);
    border-color: rgba(99, 102, 241, 0.36);
  }
  .hamburger-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .hamburger-btn span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--text-muted);
    border-radius: 9999px;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease,
      width 0.3s ease;
  }
  .hamburger-btn span:nth-child(3) {
    width: 65%;
  }

  .primary-nav {
    gap: 1.25rem;
  }

  .nav-link-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.48rem 0.78rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    box-shadow: none;
    font-size: 0.88rem;
    font-weight: 650;
    letter-spacing: 0;
    text-transform: none;
    color: #cbd5e1;
    white-space: nowrap;
    cursor: pointer;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .site-header .nav-link-sm::after {
    display: none;
  }

  .nav-link-sm:hover {
    color: #f8fafc;
    transform: translateY(-1px);
    background: rgba(30, 41, 59, 0.72);
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.1);
  }

  .nav-link-sm:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .site-header .nav-link.active {
    color: #f8fafc;
    background: rgba(30, 41, 59, 0.82);
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.14);
  }

  .overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: var(--bg-overlay);
    display: flex;
    flex-direction: column;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .overlay.open {
    opacity: 1;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    pointer-events: all;
  }

  .overlay-circuit {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 102, 241, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(14, 165, 233, 0.07) 1px, transparent 1px);
    background-size: 4rem 4rem;
    mask-image: linear-gradient(90deg, rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.75), transparent);
    -webkit-mask-image: linear-gradient(90deg, rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.75), transparent);
    opacity: 0.36;
    pointer-events: none;
  }

  .overlay-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-dim);
    cursor: pointer;
    transition:
      color 0.2s ease,
      background 0.2s ease;
    z-index: 10;
  }
  .overlay-close svg {
    width: 20px;
    height: 20px;
  }
  .overlay-close:hover {
    color: var(--text);
    background: rgba(99, 102, 241, 0.1);
  }
  .overlay-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .overlay-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    padding: 5rem 6vw 3rem;
    max-width: 860px;
    position: relative;
    z-index: 2;
  }

  .overlay-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 2.5rem;
  }

  .overlay-eyebrow::before {
    content: '';
    display: inline-block;
    width: 0.46rem;
    height: 0.46rem;
    margin-right: 0.62rem;
    border-radius: 999px;
    background: var(--neon);
    box-shadow: 0 0 12px rgba(14, 165, 233, 0.5);
    vertical-align: 0.08rem;
  }

  .overlay-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .overlay-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text-muted);
    position: relative;
    overflow: hidden;

    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.45s ease calc(var(--i) * 0.07s),
      transform 0.45s cubic-bezier(0.22, 1, 0.36, 1) calc(var(--i) * 0.07s),
      color 0.2s ease;
  }
  .overlay.open .overlay-link {
    opacity: 1;
    transform: translateY(0);
  }

  .overlay-link:hover {
    color: var(--text);
  }

  .overlay-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(99, 102, 241, 0.05);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .overlay-link:hover::before {
    opacity: 1;
  }

  .overlay-num {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--text-dimmer);
    min-width: 2rem;
    transition: color 0.2s ease;
  }
  .overlay-link:hover .overlay-num {
    color: rgba(99, 102, 241, 0.7);
  }

  .overlay-link-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
  }

  .overlay-link-label {
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--text);
    transition: color 0.25s ease;
  }
  .overlay-link:hover .overlay-link-label {
    color: var(--accent);
  }

  .overlay-link-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }
  .overlay-link:hover .overlay-link-desc {
    color: var(--text-muted);
  }

  .overlay-arrow {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--text-dimmer);
    flex-shrink: 0;
    transition:
      color 0.2s ease,
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .overlay-link:hover .overlay-arrow {
    color: #a5b4fc;
    transform: translate(4px, -4px);
  }

  .overlay-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    margin-top: 1rem;
  }

  .overlay-bottom-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    width: 100%;
    margin-bottom: 0.1rem;
  }

  .overlay-quick-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    transition: color 0.2s ease;
  }
  .overlay-quick-link:hover {
