---
import resumeData from '../data/resume.json';

type ExperienceItem = {
  title: string;
  company: string;
  period: string;
  description?: string;
  bullets?: string[];
};

const experiences = resumeData.experiences as ExperienceItem[];
---

<section id="experience" class="experience-section" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">
        Expériences professionnelles
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">
        Expériences professionnelles
      </h2>
    </div>

    <div class="experience-timeline max-w-5xl mx-auto">
      {
        experiences.map((item, index) => (
          <article class="experience-item reveal" style={`transition-delay: ${index * 0.08}s;`}>
            <div class="experience-marker" aria-hidden="true" />
            <div class="experience-card">
              <div class="experience-header">
                <div>
                  <h3>{item.title}</h3>
                  <p class="experience-company">{item.company}</p>
                </div>
                <span class="experience-period">{item.period}</span>
              </div>

              {item.description && <p class="experience-description">{item.description}</p>}

              {item.bullets && item.bullets.length > 0 && (
                <ul class="experience-bullets">
                  {item.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('#experience .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.08 }
    );
    io.observe(el);
  });
</script>

<style>
  .experience-section {
    padding: 6rem 0;
    background: rgba(15, 23, 42, 0.3);
  }

  .experience-timeline {
    --timeline-marker-column: 1.25rem;
    --timeline-marker-size: 0.75rem;
    --timeline-end-size: 0.58rem;
    --timeline-line-width: 1px;
    --timeline-line-x: calc((var(--timeline-marker-column) - var(--timeline-line-width)) / 2);
    --timeline-marker-x: calc((var(--timeline-marker-column) - var(--timeline-marker-size)) / 2);
    --timeline-end-x: calc((var(--timeline-marker-column) - var(--timeline-end-size)) / 2);
    position: relative;
    display: grid;
    gap: 1.2rem;
    padding-bottom: 1rem;
  }

  .experience-timeline::before {
    content: '';
    position: absolute;
    top: calc(1.45rem + (var(--timeline-marker-size) / 2));
    bottom: calc(var(--timeline-end-size) / 2);
    left: var(--timeline-line-x);
    width: var(--timeline-line-width);
    background: linear-gradient(180deg, rgba(14, 165, 233, 0.62), rgba(99, 102, 241, 0.15));
  }

  .experience-timeline::after {
    content: '';
    position: absolute;
    z-index: 1;
    left: var(--timeline-end-x);
    bottom: 0;
    width: var(--timeline-end-size);
    height: var(--timeline-end-size);
    border: 1px solid rgba(56, 189, 248, 0.62);
    border-radius: 999px;
    background: #020617;
    box-shadow:
      0 0 0 5px rgba(56, 189, 248, 0.08),
      0 0 18px rgba(56, 189, 248, 0.28);
  }

  .experience-item {
    position: relative;
    display: grid;
    grid-template-columns: var(--timeline-marker-column) minmax(0, 1fr);
    gap: 1.2rem;
  }

  .experience-marker {
    position: relative;
    z-index: 1;
    justify-self: start;
    width: var(--timeline-marker-size);
    height: var(--timeline-marker-size);
    margin-left: var(--timeline-marker-x);
    margin-top: 1.45rem;
    border-radius: 999px;
    background: #38bdf8;
    box-shadow: 0 0 0 5px rgba(56, 189, 248, 0.12);
  }

  .experience-card {
    border: 1px solid rgba(99, 102, 241, 0.18);
    border-radius: 0.9rem;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.86), rgba(2, 6, 23, 0.72)),
      var(--bg-card);
    padding: 1.35rem;
    box-shadow: 0 18px 52px rgba(2, 6, 23, 0.24);
  }

  .experience-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .experience-header h3 {
    margin: 0;
    color: var(--text);
    font-size: 1.05rem;
    font-weight: 850;
    line-height: 1.3;
  }

  .experience-company {
    margin: 0.35rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-style: italic;
    line-height: 1.45;
  }

  .experience-period {
    flex: 0 0 auto;
    color: #c4b5fd;
    font-size: 0.82rem;
    font-weight: 700;
    text-align: right;
    line-height: 1.4;
  }

  .experience-description {
    margin: 0.95rem 0 0;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .experience-bullets {
    display: grid;
    gap: 0.52rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .experience-bullets li {
    position: relative;
    padding-left: 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.58;
  }

  .experience-bullets li::before {
    content: '';
    position: absolute;
    top: 0.68em;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #34d399;
  }

  :global([data-theme='light']) .experience-section {
    background: rgba(241, 245, 249, 0.76);
  }

  :global([data-theme='light']) .experience-card {
    background: var(--bg-card);
    border-color: rgba(99, 102, 241, 0.14);
    box-shadow: 0 16px 42px rgba(15, 23, 42, 0.08);
  }

  :global([data-theme='light']) .experience-timeline::after {
    background: #f8fafc;
  }

  @media (max-width: 640px) {
    .experience-header {
      display: grid;
      gap: 0.7rem;
    }

    .experience-period {
      text-align: left;
    }
  }
</style>
