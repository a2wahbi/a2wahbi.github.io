---
import personalData from '../data/personal.json';
import siteData from '../data/site.json';
import menuData from '../data/menu.json';
import { getSocialLinks } from '../lib/socialLinks';

const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const socialLinks = getSocialLinks(personalData as unknown as Record<string, string | string[]>);

const navLinks = menuData.sections.map((s) => ({ label: s.label, href: s.href }));

const { footerAttribution } = siteData;
---

<footer
  id="site-footer"
  style="position: relative; background: var(--footer-bg); border-top: 1px solid var(--footer-border);"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl py-14">
    <div class="footer-grid">
      <div class="footer-left">
        <div class="footer-square" id="footer-square">
          <div class="footer-scope" role="img" aria-label="Signal électronique animé">
            <svg class="footer-scope-svg" viewBox="0 0 170 85" aria-hidden="true" focusable="false">
              <path
                class="scope-trace scope-trace-glow"
                d="M8 44 H22 L27 31 L34 58 L41 44 H55 C62 44 62 27 70 27 C78 27 78 60 86 60 C94 60 94 44 102 44 H116 L121 35 L126 51 L132 44 H162"
              />
              <path
                class="scope-trace scope-trace-main"
                d="M8 44 H22 L27 31 L34 58 L41 44 H55 C62 44 62 27 70 27 C78 27 78 60 86 60 C94 60 94 44 102 44 H116 L121 35 L126 51 L132 44 H162"
              />
              <path
                class="scope-noise"
                d="M10 68 L15 65 L20 69 L26 66 L31 68 L37 64 L43 67 L50 66 L57 69 L64 65 L72 68 L80 66 L88 69 L96 65 L104 67 L112 66 L121 68 L130 65 L139 69 L148 66 L160 68"
              />
            </svg>
            <span class="scope-sweep" aria-hidden="true"></span>
            <span class="scope-dot scope-dot-a" aria-hidden="true"></span>
            <span class="scope-dot scope-dot-b" aria-hidden="true"></span>
          </div>
        </div>

        <div class="mt-4">
          <p class="text-lg font-bold gradient-text">{personalData.name}</p>
          <p class="text-slate-500 text-xs mt-1 leading-relaxed max-w-[220px]">
            {siteData.tagline}
          </p>
          <a href={`mailto:${personalData.email}`} class="footer-email mt-3">
            <svg
              class="w-4 h-4 opacity-50 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            {personalData.email}
          </a>
        </div>
      </div>

      <div class="footer-center">
        <nav class="flex flex-col gap-2" aria-label="Footer navigation">
          {
            navLinks.map((link) => (
              <a href={link.href} class="footer-nav-link">
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>

      <div class="footer-right">
        <div class="flex flex-wrap gap-2">
          {siteData.seoKeywords.map((kw) => <span class="footer-kw">{kw}</span>)}
        </div>
      </div>
    </div>
    <div class="footer-divider my-8"></div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-600 text-sm">
        © {currentYear}
        {personalData.name}
        {
          footerAttribution.builder && (
            <>
              {' '}
              ·{' '}
              <a href={footerAttribution.builderUrl} target="_blank" rel="noopener noreferrer">
                Développé avec {footerAttribution.builder}
              </a>
            </>
          )
        }
        {
          footerAttribution.host && (
            <>
              {' '}
              ·{' '}
              <a href={footerAttribution.hostUrl} target="_blank" rel="noopener noreferrer">
                Code source sur {footerAttribution.host}
              </a>
            </>
          )
        }
        &nbsp;·&nbsp;<a href={`${base}privacy.html`} class="hover:text-accent transition-colors">Confidentialité</a 
        >&nbsp;·&nbsp;<a href={`${base}terms.html`} class="hover:text-accent transition-colors">Mentions légales</a>
      </p>
      <div class="flex items-center gap-5">
        {
          socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social"
              aria-label={link.label}
            >
              <iconify-icon icon={link.icon} width="20" height="20" aria-hidden="true" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: auto 1fr auto;
      gap: 3rem;
    }
  }

  .footer-left {
    display: flex;
    flex-direction: column;
  }
  .footer-center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .footer-right {
    text-align: right;
  }

  @media (max-width: 767px) {
    .footer-center {
      text-align: left;
      align-items: flex-start;
    }
    .footer-right {
      text-align: left;
    }
  }

  .footer-square {
    width: 170px;
    aspect-ratio: 2/1;
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(148, 163, 184, 0.34);
    border-radius: 0.35rem;
    background:
      radial-gradient(circle at 18% 24%, rgba(34, 211, 238, 0.16), transparent 28%),
      radial-gradient(circle at 82% 76%, rgba(99, 102, 241, 0.2), transparent 30%),
      linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(2, 6, 23, 0.98));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 16px 40px rgba(15, 23, 42, 0.18);
    padding: 0;
    cursor: default;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }

  .footer-square::before {
    content: '';
    position: absolute;
    inset: 8px;
    z-index: -1;
    opacity: 0.65;
    background:
      linear-gradient(
        90deg,
        transparent 0 14%,
        rgba(125, 211, 252, 0.38) 14% 14.8%,
        transparent 14.8% 48%,
        rgba(167, 243, 208, 0.3) 48% 48.8%,
        transparent 48.8%
      ),
      linear-gradient(
        0deg,
        transparent 0 26%,
        rgba(125, 211, 252, 0.28) 26% 26.8%,
        transparent 26.8% 70%,
        rgba(99, 102, 241, 0.34) 70% 70.8%,
        transparent 70.8%
      ),
      repeating-linear-gradient(90deg, rgba(148, 163, 184, 0.12) 0 1px, transparent 1px 16px),
      repeating-linear-gradient(0deg, rgba(148, 163, 184, 0.1) 0 1px, transparent 1px 16px);
  }

  .footer-square::after {
    content: '';
    position: absolute;
    inset: -65% -28%;
    background: linear-gradient(
      115deg,
      transparent 36%,
      rgba(125, 211, 252, 0.08) 44%,
      rgba(125, 211, 252, 0.42) 50%,
      rgba(167, 243, 208, 0.12) 56%,
      transparent 64%
    );
    transform: translateX(-72%) rotate(10deg);
    animation: footer-scan 5s ease-in-out infinite;
    pointer-events: none;
  }

  .footer-square:hover {
    transform: translateY(-2px);
    border-color: rgba(125, 211, 252, 0.65);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 18px 46px rgba(15, 23, 42, 0.24),
      0 0 28px rgba(56, 189, 248, 0.18);
  }

  .footer-scope {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .footer-scope-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .scope-trace {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 255;
    stroke-dashoffset: 255;
    animation: footer-trace 3.8s ease-in-out infinite;
  }

  .scope-trace-glow {
    stroke: rgba(125, 211, 252, 0.26);
    stroke-width: 7;
    filter: blur(2px);
  }

  .scope-trace-main {
    stroke: #a7f3d0;
    stroke-width: 2.2;
    filter: drop-shadow(0 0 6px rgba(45, 212, 191, 0.85));
  }

  .scope-noise {
    fill: none;
    stroke: rgba(203, 213, 225, 0.52);
    stroke-width: 1.1;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.58;
    animation: footer-noise 1.2s steps(2, end) infinite;
  }

  .scope-sweep {
    position: absolute;
    top: 10px;
    bottom: 10px;
    width: 1px;
    left: 0;
    background: linear-gradient(180deg, transparent, rgba(125, 211, 252, 0.82), transparent);
    box-shadow: 0 0 16px rgba(125, 211, 252, 0.78);
    animation: footer-sweep 3.8s ease-in-out infinite;
  }

  .scope-dot {
    position: absolute;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: #67e8f9;
    box-shadow:
      0 0 0 4px rgba(103, 232, 249, 0.08),
      0 0 16px rgba(103, 232, 249, 0.72);
    animation: footer-signal-pulse 2.4s ease-in-out infinite;
  }

  .scope-dot-a {
    left: 14px;
    top: 13px;
  }

  .scope-dot-b {
    right: 14px;
    bottom: 13px;
    animation-delay: 1.2s;
  }

  .footer-square:hover .scope-trace-main {
    stroke: #67e8f9;
    filter: drop-shadow(0 0 9px rgba(103, 232, 249, 0.95));
  }

  @keyframes footer-scan {
    0%,
    18% {
      opacity: 0;
      transform: translateX(-72%) rotate(10deg);
    }
    34%,
    62% {
      opacity: 1;
    }
    82%,
    100% {
      opacity: 0;
      transform: translateX(72%) rotate(10deg);
    }
  }

  @keyframes footer-trace {
    0% {
      stroke-dashoffset: 255;
      opacity: 0.5;
    }
    28%,
    72% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: -255;
      opacity: 0.58;
    }
  }

  @keyframes footer-sweep {
    0%,
    12% {
      opacity: 0;
      transform: translateX(0);
    }
    28%,
    76% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateX(170px);
    }
  }

  @keyframes footer-noise {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.42;
    }
    50% {
      transform: translateY(-2px);
      opacity: 0.72;
    }
  }

  @keyframes footer-signal-pulse {
    0%,
    100% {
      opacity: 0.45;
      transform: translateY(-50%) scale(0.72);
    }
    50% {
      opacity: 1;
      transform: translateY(-50%) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-square,
    .scope-trace-main {
      transition: none;
    }
    .footer-square::after,
    .scope-trace,
    .scope-noise,
    .scope-sweep,
    .scope-dot {
      animation: none;
    }
    .footer-square:hover {
      transform: none;
    }
  }

  .footer-nav-link {
    color: #64748b;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
    position: relative;
    display: inline-block;
  }
  .footer-nav-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, #6366f1, #0ea5e9);
    transition: width 0.3s ease;
  }
  .footer-nav-link:hover {
    color: #a5b4fc;
  }
  .footer-nav-link:hover::after {
    width: 100%;
  }

  .footer-email {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #475569;
    font-size: 0.8rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .footer-email:hover {
    color: #a5b4fc;
  }

  .footer-kw {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: #334155;
    background: rgba(99, 102, 241, 0.04);
    border: 1px solid rgba(99, 102, 241, 0.1);
    border-radius: 9999px;
    padding: 0.18rem 0.6rem;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
    cursor: default;
  }
  .footer-kw:hover {
    color: #6366f1;
    border-color: rgba(99, 102, 241, 0.3);
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(99, 102, 241, 0.4) 25%,
      rgba(14, 165, 233, 0.4) 75%,
      transparent 100%
    );
  }

  .footer-social {
    color: #334155;
    display: inline-flex;
    align-items: center;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }
  .footer-social:hover {
    color: #a5b4fc;
    transform: translateY(-2px);
  }
</style>
