---
import personalData from '../data/personal.json';
import siteData from '../data/site.json';
import { withBase } from '../lib/assetPath';
import { getSocialLinks } from '../lib/socialLinks';

const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const socialLinks = getSocialLinks(personalData as unknown as Record<string, string | string[]>);
const cvHref = withBase(personalData.cv);

const { footerAttribution } = siteData;
---

<footer
  id="site-footer"
  style="position: relative; background: var(--footer-bg); border-top: 1px solid var(--footer-border);"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl py-10">
    <div class="footer-grid">
      <div class="footer-left">
        <div class="footer-brand-card">
          <div class="footer-square" id="footer-square">
            <div class="footer-scope" role="img" aria-label="Signal électronique animé">
              <svg class="footer-scope-svg" viewBox="0 0 170 85" aria-hidden="true" focusable="false">
                <path
                  class="scope-trace scope-trace-glow"
                  d="M8 44 H22 L27 31 L34 58 L41 44 H55 C62 44 62 27 70 27 C78 27 78 60 86 60 C94 60 94 44 102 44 H116 L121 35 L126 51 L132 44 H162"
                />
                <path
                  class="scope-trace scope-trace-main"
                  d="M8 44 H22 L27 31 L34 58 L41 44 H55 C62 44 62 27 70 27 C78 27 78 60 86 60 C94 60 94 44 102 44 H116 L121 35 L126 51 L132 44 H162"
                />
                <path
                  class="scope-noise"
                  d="M10 68 L15 65 L20 69 L26 66 L31 68 L37 64 L43 67 L50 66 L57 69 L64 65 L72 68 L80 66 L88 69 L96 65 L104 67 L112 66 L121 68 L130 65 L139 69 L148 66 L160 68"
                />
              </svg>
              <span class="scope-sweep" aria-hidden="true"></span>
              <span class="scope-dot scope-dot-a" aria-hidden="true"></span>
              <span class="scope-dot scope-dot-b" aria-hidden="true"></span>
            </div>
          </div>

          <div class="footer-brand-copy">
            <p class="footer-name gradient-text">{personalData.name}</p>
            <p class="footer-tagline">{siteData.tagline}</p>
            <p class="footer-email">
            <svg
              class="w-4 h-4 opacity-50 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            {personalData.email}
            </p>
          </div>
        </div>
      </div>

      <div class="footer-center">
        <aside class="footer-opportunity-card" aria-labelledby="footer-opportunity-title">
          <div class="footer-opportunity-head">
            <div>
              <h2 id="footer-opportunity-title">Prêt pour un nouveau défi</h2>
            </div>
            <span class="footer-availability">Disponible dès sept. 2026</span>
          </div>

          <div class="footer-opportunity-facts">
            <div class="footer-opportunity-fact">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 21s6-5.1 6-11a6 6 0 1 0-12 0c0 5.9 6 11 6 11Z" />
                <circle cx="12" cy="10" r="2" stroke-width="1.8" />
              </svg>
              <div>
                <span>Mobilité</span>
                <strong>France entière</strong>
              </div>
            </div>

            <div class="footer-opportunity-fact">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <rect x="7" y="7" width="10" height="10" rx="2" stroke-width="1.8" />
                <path stroke-linecap="round" stroke-width="1.8" d="M9 2v3m6-3v3M9 19v3m6-3v3M2 9h3m-3 6h3m14-6h3m-3 6h3" />
              </svg>
              <div>
                <span>Cœur de métier</span>
                <strong>Électronique & logiciel embarqué</strong>
              </div>
            </div>

            <div class="footer-opportunity-fact">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <rect x="3" y="7" width="18" height="12" rx="2" stroke-width="1.8" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M3 12h18M10 12v2h4v-2" />
              </svg>
              <div>
                <span>Type d’opportunité</span>
                <strong>CDI</strong>
              </div>
            </div>
          </div>

          <div class="footer-opportunity-bottom">
            <a href={cvHref} target="_blank" rel="noopener noreferrer" class="footer-cv-link">
              Consulter mon CV
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17 17 7M8 7h9v9" />
              </svg>
            </a>
          </div>
        </aside>
      </div>

    </div>
    <div class="footer-divider my-8"></div>

    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-600 text-sm">
        © {currentYear}
        {personalData.name}
        {
          footerAttribution.builder && (
            <>
              {' '}
              ·{' '}
              <a href={footerAttribution.builderUrl} target="_blank" rel="noopener noreferrer">
                Développé avec {footerAttribution.builder}
              </a>
            </>
          )
        }
        {
          footerAttribution.host && (
            <>
              {' '}
              ·{' '}
              <a href={footerAttribution.hostUrl} target="_blank" rel="noopener noreferrer">
                Code source sur {footerAttribution.host}
              </a>
            </>
          )
        }
        &nbsp;·&nbsp;<a href={`${base}privacy.html`} class="hover:text-accent transition-colors">Confidentialité</a 
        >&nbsp;·&nbsp;<a href={`${base}terms.html`} class="hover:text-accent transition-colors">Mentions légales</a>
      </p>
      <div class="flex items-center gap-5">
        {
          socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-social"
              aria-label={link.label}
            >
              <iconify-icon icon={link.icon} width="20" height="20" aria-hidden="true" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: stretch;
  }
  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: minmax(12rem, 0.68fr) minmax(0, 2.32fr);
      gap: clamp(3rem, 7vw, 6rem);
    }
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-height: 0;
  }

  .footer-brand-card {
    display: flex;
    flex: 1;
    flex-direction: column;
    min-width: 0;
  }

  .footer-brand-copy {
    margin-top: 1rem;
    min-width: 0;
  }

  .footer-name {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 850;
    line-height: 1.15;
  }

  .footer-tagline {
    margin-top: 0.38rem;
    max-width: 14rem;
    color: #64748b;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .footer-center {
    display: flex;
    align-items: stretch;
    justify-content: center;
    min-width: 0;
  }

  .footer-opportunity-card {
    isolation: isolate;
    position: relative;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    width: 100%;
    max-width: 50rem;
    overflow: hidden;
    border: 1px solid rgba(56, 189, 248, 0.18);
    border-radius: 0.9rem;
    background:
      radial-gradient(circle at 95% 0%, rgba(14, 165, 233, 0.13), transparent 34%),
      linear-gradient(135deg, rgba(15, 23, 42, 0.78), rgba(2, 6, 23, 0.42));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 20px 50px rgba(2, 6, 23, 0.2);
    padding: 1rem 1.25rem;
  }

  .footer-opportunity-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.32;
    background-image:
      linear-gradient(rgba(56, 189, 248, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(56, 189, 248, 0.1) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: linear-gradient(90deg, transparent, black 54%, black);
  }

  .footer-opportunity-card::after {
    content: '';
    position: absolute;
    right: -3.5rem;
    top: -6rem;
    z-index: -1;
    width: 12rem;
    height: 12rem;
    border: 1px solid rgba(103, 232, 249, 0.14);
    border-radius: 999px;
    box-shadow:
      0 0 0 2.5rem rgba(56, 189, 248, 0.018),
      0 0 0 5rem rgba(99, 102, 241, 0.018);
  }

  .footer-opportunity-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .footer-opportunity-head h2 {
    margin: 0;
    color: #f1f5f9;
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .footer-availability {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0.38rem 0.68rem;
    border: 1px solid rgba(52, 211, 153, 0.22);
    border-radius: 999px;
    color: #a7f3d0;
    background: rgba(16, 185, 129, 0.08);
    font-size: 0.68rem;
    font-weight: 750;
    white-space: nowrap;
  }

  .footer-availability::before {
    content: '';
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: #34d399;
    box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.1), 0 0 10px rgba(52, 211, 153, 0.5);
  }

  .footer-opportunity-facts {
    display: grid;
    grid-auto-columns: minmax(0, 1fr);
    grid-auto-flow: column;
    grid-template-columns: none;
    gap: 0.75rem;
    width: 100%;
    margin: 0.8rem 0 0.75rem;
  }

  .footer-opportunity-fact {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
    min-height: 4.2rem;
    padding: 0.68rem 0.8rem;
    border: 1px solid rgba(148, 163, 184, 0.11);
    border-radius: 0.65rem;
    background: rgba(15, 23, 42, 0.38);
  }

  .footer-opportunity-fact svg {
    flex: 0 0 auto;
    width: 2rem;
    height: 2rem;
    padding: 0.43rem;
    border: 1px solid rgba(56, 189, 248, 0.16);
    border-radius: 0.55rem;
    color: #38bdf8;
    background: rgba(14, 165, 233, 0.07);
  }

  .footer-opportunity-fact div {
    min-width: 0;
  }

  .footer-opportunity-fact span,
  .footer-opportunity-fact strong {
    display: block;
  }

  .footer-opportunity-fact span {
    margin-bottom: 0.14rem;
    color: #64748b;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .footer-opportunity-fact strong {
    color: #cbd5e1;
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .footer-opportunity-bottom {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
    padding-top: 0.68rem;
    border-top: 1px solid rgba(148, 163, 184, 0.1);
  }

  .footer-cv-link {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: #7dd3fc;
    font-size: 0.72rem;
    font-weight: 750;
    white-space: nowrap;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .footer-cv-link svg {
    width: 0.95rem;
    height: 0.95rem;
    transition: transform 0.2s ease;
  }

  .footer-cv-link:hover {
    color: #ffffff;
  }

  .footer-cv-link:hover svg {
    transform: translate(0.12rem, -0.12rem);
  }

  .footer-cv-link:focus-visible {
    border-radius: 0.2rem;
    outline: 2px solid #38bdf8;
    outline-offset: 3px;
  }

  .footer-square {
    width: 170px;
    aspect-ratio: 2/1;
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(148, 163, 184, 0.34);
    border-radius: 0.35rem;
    background:
      radial-gradient(circle at 18% 24%, rgba(34, 211, 238, 0.16), transparent 28%),
      radial-gradient(circle at 82% 76%, rgba(99, 102, 241, 0.2), transparent 30%),
      linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(2, 6, 23, 0.98));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 16px 40px rgba(15, 23, 42, 0.18);
    padding: 0;
    cursor: default;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }

  .footer-square::before {
    content: '';
    position: absolute;
    inset: 8px;
    z-index: -1;
    opacity: 0.65;
    background:
      linear-gradient(
        90deg,
        transparent 0 14%,
        rgba(125, 211, 252, 0.38) 14% 14.8%,
        transparent 14.8% 48%,
        rgba(167, 243, 208, 0.3) 48% 48.8%,
        transparent 48.8%
      ),
      linear-gradient(
        0deg,
        transparent 0 26%,
        rgba(125, 211, 252, 0.28) 26% 26.8%,
        transparent 26.8% 70%,
        rgba(99, 102, 241, 0.34) 70% 70.8%,
        transparent 70.8%
      ),
      repeating-linear-gradient(90deg, rgba(148, 163, 184, 0.12) 0 1px, transparent 1px 16px),
      repeating-linear-gradient(0deg, rgba(148, 163, 184, 0.1) 0 1px, transparent 1px 16px);
  }

  .footer-square::after {
    content: '';
    position: absolute;
    inset: -65% -28%;
    background: linear-gradient(
      115deg,
      transparent 36%,
      rgba(125, 211, 252, 0.08) 44%,
      rgba(125, 211, 252, 0.42) 50%,
      rgba(167, 243, 208, 0.12) 56%,
      transparent 64%
    );
    transform: translateX(-72%) rotate(10deg);
    animation: footer-scan 5s ease-in-out infinite;
    pointer-events: none;
  }

  .footer-square:hover {
    transform: translateY(-2px);
    border-color: rgba(125, 211, 252, 0.65);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 18px 46px rgba(15, 23, 42, 0.24),
      0 0 28px rgba(56, 189, 248, 0.18);
  }

  .footer-scope {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .footer-scope-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .scope-trace {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 255;
    stroke-dashoffset: 255;
    animation: footer-trace 3.8s ease-in-out infinite;
  }

  .scope-trace-glow {
    stroke: rgba(125, 211, 252, 0.26);
    stroke-width: 7;
    filter: blur(2px);
  }

  .scope-trace-main {
    stroke: #a7f3d0;
    stroke-width: 2.2;
    filter: drop-shadow(0 0 6px rgba(45, 212, 191, 0.85));
  }

  .scope-noise {
    fill: none;
    stroke: rgba(203, 213, 225, 0.52);
    stroke-width: 1.1;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.58;
    animation: footer-noise 1.2s steps(2, end) infinite;
  }

  .scope-sweep {
    position: absolute;
    top: 10px;
    bottom: 10px;
    width: 1px;
    left: 0;
    background: linear-gradient(180deg, transparent, rgba(125, 211, 252, 0.82), transparent);
    box-shadow: 0 0 16px rgba(125, 211, 252, 0.78);
    animation: footer-sweep 3.8s ease-in-out infinite;
  }

  .scope-dot {
    position: absolute;
    width: 0.34rem;
    height: 0.34rem;
    border-radius: 999px;
    background: #67e8f9;
    box-shadow:
      0 0 0 4px rgba(103, 232, 249, 0.08),
      0 0 16px rgba(103, 232, 249, 0.72);
    animation: footer-signal-pulse 2.4s ease-in-out infinite;
  }

  .scope-dot-a {
    left: 14px;
    top: 13px;
  }

  .scope-dot-b {
    right: 14px;
    bottom: 13px;
    animation-delay: 1.2s;
  }

  .footer-square:hover .scope-trace-main {
    stroke: #67e8f9;
    filter: drop-shadow(0 0 9px rgba(103, 232, 249, 0.95));
  }

  @keyframes footer-scan {
    0%,
    18% {
      opacity: 0;
      transform: translateX(-72%) rotate(10deg);
    }
    34%,
    62% {
      opacity: 1;
    }
    82%,
    100% {
      opacity: 0;
      transform: translateX(72%) rotate(10deg);
    }
  }

  @keyframes footer-trace {
    0% {
      stroke-dashoffset: 255;
      opacity: 0.5;
    }
    28%,
    72% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
    100% {
      stroke-dashoffset: -255;
      opacity: 0.58;
    }
  }

  @keyframes footer-sweep {
    0%,
    12% {
      opacity: 0;
      transform: translateX(0);
    }
    28%,
    76% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateX(170px);
    }
  }

  @keyframes footer-noise {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.42;
    }
    50% {
      transform: translateY(-2px);
      opacity: 0.72;
    }
  }

  @keyframes footer-signal-pulse {
    0%,
    100% {
      opacity: 0.45;
      transform: translateY(-50%) scale(0.72);
    }
    50% {
      opacity: 1;
      transform: translateY(-50%) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-square,
    .scope-trace-main {
      transition: none;
    }
    .footer-square::after,
    .scope-trace,
    .scope-noise,
    .scope-sweep,
    .scope-dot {
      animation: none;
    }
    .footer-square:hover {
      transform: none;
    }
  }

  .footer-email {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #475569;
    font-size: 0.8rem;
    font-weight: 500;
    margin-top: 0.7rem;
  }

  :global([data-theme='light']) .footer-opportunity-card {
    border-color: rgba(14, 165, 233, 0.17);
    background:
      radial-gradient(circle at 95% 0%, rgba(14, 165, 233, 0.09), transparent 34%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(241, 245, 249, 0.72));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.8),
      0 18px 44px rgba(15, 23, 42, 0.06);
  }

  :global([data-theme='light']) .footer-opportunity-head h2 {
    color: #1e293b;
  }

  :global([data-theme='light']) .footer-opportunity-fact {
    border-color: rgba(99, 102, 241, 0.1);
    background: rgba(255, 255, 255, 0.55);
  }

  :global([data-theme='light']) .footer-opportunity-fact strong {
    color: #334155;
  }

  :global([data-theme='light']) .footer-cv-link:hover {
    color: #0369a1;
  }

  @media (max-width: 899px) {
    .footer-center {
      justify-content: flex-start;
    }

    .footer-opportunity-card {
      max-width: none;
    }
  }

  @media (max-width: 680px) {
    .footer-opportunity-head,
    .footer-opportunity-bottom {
      align-items: flex-start;
      flex-direction: column;
    }

    .footer-opportunity-facts {
      grid-auto-columns: auto;
      grid-auto-flow: row;
      grid-template-columns: 1fr;
    }

    .footer-opportunity-fact strong {
      overflow: visible;
      text-overflow: clip;
    }
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(99, 102, 241, 0.4) 25%,
      rgba(14, 165, 233, 0.4) 75%,
      transparent 100%
    );
  }

  .footer-social {
    color: #334155;
    display: inline-flex;
    align-items: center;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
  }
  .footer-social:hover {
    color: #a5b4fc;
    transform: translateY(-2px);
  }
</style>
