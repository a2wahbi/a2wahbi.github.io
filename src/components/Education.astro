---
import resumeData from '../data/resume.json';

type EducationItem = {
  title: string;
  school: string;
  period: string;
};

const education = resumeData.education as EducationItem[];
const languages = resumeData.languages as string[];
const interests = resumeData.interests as string[];
---

<section id="education" class="education-section" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">
        Formation
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">
        Formation
      </h2>
    </div>

    <div class="education-layout max-w-6xl mx-auto">
      <div class="education-card reveal">
        <h3>Formation</h3>
        <div class="education-list">
          {
            education.map((item) => (
              <article>
                <h4>{item.title}</h4>
                <p>{item.school}</p>
                <span>{item.period}</span>
              </article>
            ))
          }
        </div>
      </div>

      <div class="education-side">
        <div class="education-card reveal" style="transition-delay: 0.08s;">
          <h3>Langues</h3>
          <ul>
            {languages.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="education-card reveal" style="transition-delay: 0.16s;">
          <h3>Centres d’intérêt</h3>
          <ul>
            {interests.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('#education .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(el);
  });
</script>

<style>
  .education-section {
    padding: 6rem 0;
  }

  .education-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }

  @media (min-width: 900px) {
    .education-layout {
      grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.55fr);
    }
  }

  .education-side {
    display: grid;
    gap: 1.2rem;
  }

  .education-card {
    border: 1px solid rgba(99, 102, 241, 0.18);
    border-radius: 0.9rem;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.84), rgba(2, 6, 23, 0.68)),
      var(--bg-card);
    padding: 1.4rem;
    box-shadow: 0 18px 52px rgba(2, 6, 23, 0.22);
  }

  .education-card h3 {
    margin: 0 0 1rem;
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .education-list {
    display: grid;
    gap: 1.1rem;
  }

  .education-list article {
    border-left: 2px solid rgba(56, 189, 248, 0.42);
    padding-left: 1rem;
  }

  .education-list h4 {
    margin: 0;
    color: var(--text);
    font-size: 1rem;
    font-weight: 850;
    line-height: 1.35;
  }

  .education-list p {
    margin: 0.4rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-style: italic;
    line-height: 1.45;
  }

  .education-list span {
    display: inline-flex;
    margin-top: 0.45rem;
    color: #c4b5fd;
    font-size: 0.84rem;
    font-weight: 750;
  }

  .education-card ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .education-card li {
    position: relative;
    padding-left: 1rem;
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .education-card li::before {
    content: '';
    position: absolute;
    top: 0.66em;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #34d399;
  }

  :global([data-theme='light']) .education-card {
    background: var(--bg-card);
    border-color: rgba(99, 102, 241, 0.14);
    box-shadow: 0 16px 42px rgba(15, 23, 42, 0.08);
  }
</style>
