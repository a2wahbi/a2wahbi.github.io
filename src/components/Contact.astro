---
import personalData from '../data/personal.json';
import siteData from '../data/site.json';
import { getSocialLinks } from '../lib/socialLinks';

const socialLinks = getSocialLinks(personalData as unknown as Record<string, string | string[]>);
---

<section
  id="contact"
  class="py-24"
  style="background: var(--bg-section); position: relative; z-index: 5; scroll-margin-top: 80px;"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 reveal">
        <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">
          Contact
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">
          Échangeons sur votre projet
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-4 reveal" style="transition-delay: 0.1s;">
          {personalData.email && (
          <div class="card">
            <div class="flex items-center gap-4">
              <div
                class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-semibold text-sm">E-mail</h3>
                <p class="text-slate-400 text-sm">
                  {personalData.email}
                </p>
              </div>
            </div>
          </div>
          )}

          {
            personalData.phone && (
              <div class="card">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                    <svg
                      class="w-5 h-5 text-accent"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                      />
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-white font-semibold text-sm">Téléphone</h3>
                    <p class="text-slate-400 text-sm">
                      {personalData.phone}
                    </p>
                  </div>
                </div>
              </div>
            )
          }

          <div class="card">
            <div class="flex items-center gap-4">
              <div
                class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-semibold text-sm">Localisation</h3>
                <p class="text-slate-400 text-sm">{personalData.location}</p>
              </div>
            </div>
          </div>

          {
            socialLinks.length > 0 && (
              <div class="card">
                <h3 class="text-white font-semibold text-sm mb-4">
                  Retrouvez-moi également
                </h3>
                <div class="flex flex-wrap gap-4">
                  {socialLinks.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="contact-social-link"
                      aria-label={link.label}
                    >
                      <iconify-icon icon={link.icon} width="20" height="20" aria-hidden="true" />
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <div class="contact-form-card card reveal" style="transition-delay: 0.2s;">
          <form id="contact-form" class="contact-form">
            <input type="hidden" name="access_key" value={siteData.web3formsKey} />
            <input type="hidden" name="from_name" value="Portfolio WAHBI Amine" />
            <input type="hidden" name="subject" value="[Portfolio] Nouveau message de contact" />
            <!-- Champ anti-spam invisible : les robots le remplissent souvent.
                 Web3Forms rejette les soumissions lorsque ce champ est coché. -->
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display:none;"
              aria-hidden="true"
            />
            <div class="grid grid-cols-1 sm:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] gap-4">
              <div>
                <label
                  for="name"
                  class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"
                  >Nom</label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  autocomplete="name"
                  required
                  class="w-full bg-slate-900/60 border border-slate-700/60 rounded-lg px-4 py-3 text-white text-sm focus:outline-hidden focus-visible:border-accent focus-visible:ring-1 focus-visible:ring-accent/50 transition-colors placeholder:text-slate-600"
                  placeholder="Votre nom"
                />
              </div>
              <div>
                <label
                  for="email"
                  class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"
                  >E-mail</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  inputmode="email"
                  spellcheck="false"
                  required
                  class="w-full bg-slate-900/60 border border-slate-700/60 rounded-lg px-4 py-3 text-white text-sm focus:outline-hidden focus-visible:border-accent focus-visible:ring-1 focus-visible:ring-accent/50 transition-colors placeholder:text-slate-600"
                  placeholder="example@example.com"
                />
              </div>
            </div>

            <div>
              <label
                for="subject"
                class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"
                >Sujet</label
              >
              <input
                type="text"
                id="subject"
                name="objet"
                autocomplete="off"
                required
                class="w-full bg-slate-900/60 border border-slate-700/60 rounded-lg px-4 py-3 text-white text-sm focus:outline-hidden focus-visible:border-accent focus-visible:ring-1 focus-visible:ring-accent/50 transition-colors placeholder:text-slate-600"
                placeholder="Objet de votre message"
              />
            </div>

            <div class="contact-message-field">
              <label
                for="message"
                class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"
                >Message</label
              >
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full bg-slate-900/60 border border-slate-700/60 rounded-lg px-4 py-3 text-white text-sm focus:outline-hidden focus-visible:border-accent focus-visible:ring-1 focus-visible:ring-accent/50 transition-colors resize-none placeholder:text-slate-600"
                placeholder="Décrivez votre besoin, votre projet ou votre opportunité."></textarea>
            </div>

            <div aria-live="polite" aria-atomic="true" id="form-status" class="sr-only"></div>
            <button type="submit" class="contact-submit btn-primary w-full">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="send-icon w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"
                ></path>
                <path d="m21.854 2.147-10.94 10.939"></path>
              </svg>
              <span>Envoyer le message</span>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('#contact .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(el);
  });

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLElement | null;
  const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  // Mémorise le contenu initial du bouton avant de le remplacer par l'état d'envoi.
  // Le contenu est restauré ensuite pour conserver l'icône et le libellé d'origine.
  const BUTTON_HTML = button?.innerHTML ?? 'Envoyer le message';

  function setStatus(msg: string, isError: boolean) {
    if (!status) return;
    status.textContent = msg;
    status.className = isError ? 'mt-3 text-sm text-red-400' : 'mt-3 text-sm text-green-400';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      setStatus('Merci de compléter les champs obligatoires avant l’envoi.', true);
      return;
    }

    if (button) {
      button.disabled = true;
      button.textContent = 'Envoi en cours…';
    }
    setStatus('', false);

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form!),
      });
      const data = (await res.json()) as { success?: boolean; message?: string };
      if (res.ok && data.success) {
        setStatus('Message envoyé. Je vous répondrai dès que possible.', false);
        form!.reset();
      } else {
        setStatus(data.message ?? 'Une erreur est survenue. Merci de réessayer.', true);
      }
    } catch {
      setStatus('Erreur réseau. Vous pouvez aussi me contacter directement par e-mail.', true);
    } finally {
      if (button) {
        button.disabled = false;
        button.innerHTML = BUTTON_HTML;
      }
    }
  });
</script>

<style>
  .contact-social-link {
    color: #64748b;
    display: inline-flex;
    align-items: center;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
    border-radius: 0.125rem;
  }
  .contact-social-link:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }
  .contact-social-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  :global([data-theme='light']) .text-white {
    color: black;
  }
  :global([data-theme='light']) #contact textarea,
  :global([data-theme='light']) #contact input {
    background: white !important;
  }

  #contact .contact-form-card {
    overflow: hidden;
    padding: 1.15rem;
  }

  #contact .contact-form {
    display: grid;
    grid-template-rows: auto auto minmax(0, 1fr) auto;
    gap: 0.78rem;
    height: 100%;
  }

  #contact .contact-message-field {
    display: flex;
    min-height: 0;
    flex-direction: column;
  }

  #contact .contact-form label {
    margin-bottom: 0.35rem;
  }

  #contact .contact-form input,
  #contact .contact-form textarea {
    padding-top: 0.68rem;
    padding-bottom: 0.68rem;
  }

  #contact textarea {
    flex: 1;
    min-height: 6.25rem;
  }

  #contact .contact-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    min-height: 2.9rem;
    padding: 0.72rem 1.25rem;
    overflow: hidden;
    text-align: center;
    border-radius: 0.7rem;
  }

  #contact .contact-submit .send-icon {
    flex: 0 0 auto;
    transition:
      transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 200ms ease;
    will-change: transform;
    transform: translateX(0) translateY(0) scale(1.15) rotate(-10deg);
    opacity: 1;
  }

  #contact .contact-submit span {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  #contact .contact-submit:hover .send-icon {
    transform: translateX(0.18rem) translateY(-0.08rem) scale(1.15) rotate(-16deg);
  }
</style>
