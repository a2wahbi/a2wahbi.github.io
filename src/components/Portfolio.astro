---
import portfolioData from '../data/portfolio.json';

type PortfolioAxis = {
  title: string;
  category: string;
  description: string;
  bullets?: string[];
};

const axes = portfolioData as PortfolioAxis[];
---

<section id="portfolio" class="portfolio-section" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">
        Vitrine technique
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">
        Axes du projet quadrupède
      </h2>
      <p class="portfolio-intro">
        Une lecture structurée du projet phare : architecture, électronique, firmware,
        locomotion et validation progressive.
      </p>
    </div>

    <div class="portfolio-axis-grid">
      {
        axes.map((axis, index) => (
          <article class="axis-card reveal" style={`--axis-index: ${index};`}>
            <div class="axis-visual" aria-hidden="true">
              <span class="axis-line axis-line-a" />
              <span class="axis-line axis-line-b" />
              <span class="axis-line axis-line-c" />
              <span class="axis-node axis-node-a" />
              <span class="axis-node axis-node-b" />
              <span class="axis-node axis-node-c" />
            </div>

            <div class="axis-content">
              <span class="axis-category">{axis.category}</span>
              <h3>{axis.title}</h3>
              <p>{axis.description}</p>
              {axis.bullets && axis.bullets.length > 0 && (
                <ul>
                  {axis.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('#portfolio .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.08 }
    );
    io.observe(el);
  });
</script>

<style>
  .portfolio-section {
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  .portfolio-intro {
    margin: 1rem auto 0;
    max-width: 42rem;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .portfolio-axis-grid {
    display: grid;
    gap: 1.25rem;
    max-width: 1180px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .portfolio-axis-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .axis-card {
    position: relative;
    min-height: 27rem;
    overflow: hidden;
    border: 1px solid rgba(99, 102, 241, 0.18);
    border-radius: 1rem;
    background:
      radial-gradient(circle at 18% 14%, rgba(56, 189, 248, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(15, 23, 42, 0.88), rgba(2, 6, 23, 0.76)),
      var(--bg-card);
    box-shadow: 0 24px 70px rgba(2, 6, 23, 0.28);
    transition:
      transform 0.32s ease,
      border-color 0.32s ease,
      box-shadow 0.32s ease;
  }

  .axis-card:hover {
    transform: translateY(-6px);
    border-color: rgba(56, 189, 248, 0.42);
    box-shadow: 0 30px 90px rgba(2, 6, 23, 0.4);
  }

  .axis-visual {
    position: relative;
    height: 12rem;
    overflow: hidden;
    border-bottom: 1px solid rgba(148, 163, 184, 0.16);
    background:
      linear-gradient(90deg, rgba(56, 189, 248, 0.1), transparent 38%),
      repeating-linear-gradient(90deg, rgba(148, 163, 184, 0.1) 0 1px, transparent 1px 24px),
      repeating-linear-gradient(0deg, rgba(148, 163, 184, 0.08) 0 1px, transparent 1px 24px);
  }

  .axis-line,
  .axis-node {
    position: absolute;
    display: block;
  }

  .axis-line {
    --axis-line-height: 2px;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(56, 189, 248, 0.75), transparent);
  }

  .axis-line-a {
    top: 32%;
    left: 12%;
    width: 68%;
  }

  .axis-line-b {
    top: 56%;
    left: 28%;
    width: 56%;
  }

  .axis-line-c {
    top: 72%;
    left: 8%;
    width: 74%;
  }

  .axis-node {
    --axis-node-size: 10px;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #e0f2fe;
    border: 2px solid rgba(56, 189, 248, 0.72);
    box-shadow: 0 0 18px rgba(56, 189, 248, 0.55);
    transform: translate(-50%, -50%);
  }

  .axis-node-a {
    top: calc(32% + 1px);
    left: 35%;
  }

  .axis-node-b {
    top: calc(56% + 1px);
    left: 68%;
  }

  .axis-node-c {
    top: calc(72% + 1px);
    left: 48%;
  }

  .axis-content {
    padding: 1.35rem;
  }

  .axis-category {
    display: inline-flex;
    margin-bottom: 0.7rem;
    color: #38bdf8;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .axis-content h3 {
    margin: 0;
    color: var(--text);
    font-size: 1.2rem;
    font-weight: 900;
    line-height: 1.18;
  }

  .axis-content p {
    margin: 0.75rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .axis-content ul {
    display: grid;
    gap: 0.45rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .axis-content li {
    position: relative;
    padding-left: 1rem;
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .axis-content li::before {
    content: '';
    position: absolute;
    top: 0.62em;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #34d399;
    box-shadow: 0 0 10px rgba(52, 211, 153, 0.45);
  }

  :global([data-theme='light']) .axis-card {
    background: var(--bg-card);
    border-color: rgba(99, 102, 241, 0.14);
    box-shadow: 0 16px 42px rgba(15, 23, 42, 0.08);
  }

  :global([data-theme='light']) .axis-card:hover {
    box-shadow: 0 22px 54px rgba(15, 23, 42, 0.12);
  }

  :global([data-theme='light']) .axis-visual {
    background:
      linear-gradient(90deg, rgba(14, 165, 233, 0.12), transparent 38%),
      repeating-linear-gradient(90deg, rgba(100, 116, 139, 0.12) 0 1px, transparent 1px 24px),
      repeating-linear-gradient(0deg, rgba(100, 116, 139, 0.1) 0 1px, transparent 1px 24px);
  }
</style>
