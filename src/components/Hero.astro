---
import personalData from '../data/personal.json';
import projectsFile from '../data/projects.json';
import { withBase } from '../lib/assetPath';
import { getSocialLinks } from '../lib/socialLinks';
import { existsSync, readdirSync } from 'node:fs';
import { extname, join } from 'node:path';

const heroSocialLinks = getSocialLinks(
  personalData as unknown as Record<string, string | string[]>,
  personalData.heroSocialLinks
);

const cvValue = (personalData.cv ?? '').trim();
const isExternalCv = /^https?:\/\//i.test(cvValue);
const hasLocalCv =
  cvValue.startsWith('/') &&
  existsSync(join(process.cwd(), 'public', cvValue.replace(/^\//, '')));

let discoveredCv = '';
const cvPublicDir = join(process.cwd(), 'public', 'cv');
if (!isExternalCv && !hasLocalCv && existsSync(cvPublicDir)) {
  const allowedCvExt = new Set(['.pdf', '.doc', '.docx']);
  const candidates = readdirSync(cvPublicDir)
    .filter((file) => allowedCvExt.has(extname(file).toLowerCase()))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }));
  if (candidates.length > 0) discoveredCv = `/cv/${candidates[0]}`;
}

const cvPath = isExternalCv ? cvValue : hasLocalCv ? cvValue : discoveredCv;
const hasCv = Boolean(cvPath);
const cvHref = isExternalCv ? cvPath : cvPath ? withBase(cvPath) : '';

const capabilities = [
  { value: 'Langages', label: 'C, C++, Python, VHDL.' },
  { value: 'Logiciel embarqué', label: 'Embedded Linux, multicœurs ARM, FreeRTOS, ROS 2, gestion multitâche.' },
  { value: 'Électronique', label: 'Conception et tests de cartes électroniques, électronique analogique/numérique, intégration capteurs/actionneurs.' },
];

const teaserByProject = new Map([
  [
    'Reconnaissance de caractères manuscrits par IA embarquée sur STM32',
    'Du modèle CNN au déploiement sur microcontrôleur, avec une logique pensée pour les contraintes embarquées.',
  ],
  [
    'Banc de test motorisé avec glissière à vis/écrou',
    'Automatisation, supervision et validation d’un banc motorisé pour essais mécaniques contrôlés.',
  ],
  [
    'Robot polyvalent autonome',
    'Architecture robotique distribuée combinant commande temps réel, perception et interface de pilotage.',
  ],
  [
    'Réseau de capteurs & IHM',
    'Acquisition multi-capteurs, communication CAN et visualisation des données sur interface de supervision.',
  ],
  [
    'Robot mobile',
    'Prototype mobile associant pilotage distant, acquisition de capteurs et étude cinématique.',
  ],
  [
    'Gestion automatisée de parking (système RFID)',
    'Contrôle d’accès automatisé avec badge RFID, commande de barrière et affichage temps réel.',
  ],
]);

const projectSlides = projectsFile.items
  .filter((project) => project.featured)
  .sort((a, b) => (a.sliderOrder ?? 0) - (b.sliderOrder ?? 0))
  .map((project) => ({
    label: project.category,
    title: project.title,
    teaser: teaserByProject.get(project.title) ?? 'Projet embarqué mené de la conception à la validation technique.',
    image: project.backgroundImage || (project as any).images?.[0] || '',
  }));
---

<section id="home" class="hero-section" aria-labelledby="hero-title">
  <div class="hero-background" aria-hidden="true">
    <div class="hero-signal-field">
      <span class="signal-wave signal-wave-a"></span>
      <span class="signal-wave signal-wave-b"></span>
      <span class="signal-wave signal-wave-c"></span>
    </div>
    <div class="hero-circuit-lines">
      <span class="trace trace-a"></span>
      <span class="trace trace-b"></span>
      <span class="trace trace-c"></span>
      <span class="trace trace-d"></span>
    </div>
  </div>

  <div class="hero-shell">
    <div class="hero-copy">
      <p class="hero-kicker hero-animate" style="--delay: 80ms;">
        {personalData.title}
      </p>

      <h1 id="hero-title" class="hero-title hero-animate" style="--delay: 160ms;">
        {personalData.name}
      </h1>

      <p class="hero-lead hero-animate" style="--delay: 240ms;">
        {personalData.bio}
      </p>

      <div class="hero-actions hero-animate" style="--delay: 320ms;">
        <a href="#projects" class="hero-btn hero-btn-primary">Voir mes projets</a>
        {
          hasCv ? (
            <a href={cvHref} target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn-secondary">
              Télécharger mon CV
            </a>
          ) : (
            <button type="button" onclick="window.print()" class="hero-btn hero-btn-secondary">
              Imprimer mon CV
            </button>
          )
        }
      </div>

      <div class="hero-meta hero-animate" style="--delay: 400ms;" aria-label="Compétences">
        {
          capabilities.map((item) => (
            <div class="hero-meta-item">
              <strong>{item.value}</strong>
              <span>{item.label}</span>
            </div>
          ))
        }
      </div>

      {
        heroSocialLinks.length > 0 && (
          <div class="hero-socials hero-animate" style="--delay: 480ms;" aria-label="Liens sociaux">
            {heroSocialLinks.map((link) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="hero-social-link" aria-label={link.label}>
                <iconify-icon icon={link.icon} width="20" height="20" aria-hidden="true" />
                <span>{link.label}</span>
              </a>
            ))}
          </div>
        )
      }
    </div>

    <div class="hero-visual hero-animate" style="--delay: 260ms;">
      <div
        class="project-carousel"
        role="region"
        aria-label="Carrousel de présentation des projets techniques"
        aria-roledescription="carrousel"
      >
        <div class="carousel-header">
          <strong>Projets</strong>
        </div>

        <div class="carousel-viewport">
          <div class="carousel-track" data-hero-carousel-track aria-live="polite">
            {
              projectSlides.map((slide, index) => (
                <article
                  class="project-slide"
                  data-hero-slide
                  role="group"
                  aria-label={`${slide.label} : ${slide.title}`}
                  aria-hidden={index === 0 ? 'false' : 'true'}
                  aria-roledescription="diapositive"
                >
                  <div class={`project-art${slide.image ? ' has-project-image' : ''}`} aria-hidden="true">
                    {slide.image && (
                      <img
                        class="project-art-image"
                        src={withBase(slide.image)}
                        alt=""
                        loading={index === 0 ? 'eager' : 'lazy'}
                        width="900"
                        height="560"
                      />
                    )}
                    {!slide.image && (
                      <div class="project-art-summary">
                        <div class="art-grid"></div>
                        <span class="project-art-kicker">Système embarqué</span>
                        <strong>Conception · Firmware · Validation</strong>
                      </div>
                    )}
                  </div>

                  <div class="project-slide-content">
                    <span class="project-slide-label">{slide.label}</span>
                    <h2>{slide.title}</h2>
                    <p>{slide.teaser}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <div class="carousel-controls">
          <button type="button" class="carousel-arrow" data-hero-carousel-prev aria-label="Projet précédent">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 19 8 12l7-7" />
            </svg>
          </button>

          <div class="carousel-dots" aria-label="Pagination du carrousel">
            {
              projectSlides.map((_, index) => (
                <button
                  type="button"
                  class={`carousel-dot${index === 0 ? ' is-active' : ''}`}
                  data-hero-carousel-dot={index}
                  aria-label={`Afficher le projet ${index + 1}`}
                  aria-current={index === 0 ? 'true' : 'false'}
                />
              ))
            }
          </div>

          <button type="button" class="carousel-arrow" data-hero-carousel-next aria-label="Projet suivant">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m9 5 7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    isolation: isolate;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 8rem 0 5rem;
    color: #e2e8f0;
    background:
      linear-gradient(180deg, rgba(2, 6, 23, 0.98), rgba(15, 23, 42, 0.94)),
      #020617;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
  }

  .hero-signal-field {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background:
      linear-gradient(112deg, transparent 0 18%, rgba(56, 189, 248, 0.11) 18.12% 18.24%, transparent 18.36% 100%),
      linear-gradient(64deg, transparent 0 64%, rgba(45, 212, 191, 0.08) 64.08% 64.2%, transparent 64.32% 100%),
      linear-gradient(180deg, transparent 0 27%, rgba(148, 163, 184, 0.055) 27.08% 27.16%, transparent 27.24% 100%),
      linear-gradient(126deg, rgba(14, 165, 233, 0.08), transparent 34%, rgba(20, 184, 166, 0.055));
    mask-image: linear-gradient(180deg, black 0%, black 74%, transparent 100%);
    -webkit-mask-image: linear-gradient(180deg, black 0%, black 74%, transparent 100%);
  }

  .hero-signal-field::before,
  .hero-signal-field::after {
    content: '';
    position: absolute;
    width: min(40rem, 52vw);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(125, 211, 252, 0.42), transparent);
  }

  .hero-signal-field::before {
    top: 18%;
    right: 7%;
  }

  .hero-signal-field::after {
    left: 9%;
    bottom: 24%;
    background: linear-gradient(90deg, transparent, rgba(94, 234, 212, 0.32), transparent);
  }

  .signal-wave {
    position: absolute;
    display: block;
    width: min(34rem, 52vw);
    height: 4.5rem;
    opacity: 0.34;
    background:
      linear-gradient(90deg, transparent 0 7%, currentColor 7% 7.4%, transparent 7.4% 16%),
      linear-gradient(90deg, transparent 16% 24%, currentColor 24% 24.4%, transparent 24.4% 34%),
      linear-gradient(90deg, transparent 34% 49%, currentColor 49% 49.4%, transparent 49.4% 63%),
      linear-gradient(90deg, transparent 63% 77%, currentColor 77% 77.4%, transparent 77.4% 100%),
      linear-gradient(180deg, transparent 0 49%, currentColor 49% 51%, transparent 51% 100%);
    color: rgba(56, 189, 248, 0.55);
    filter: drop-shadow(0 0 10px rgba(56, 189, 248, 0.18));
  }

  .signal-wave-a {
    top: 28%;
    right: 10%;
  }

  .signal-wave-b {
    left: 8%;
    bottom: 32%;
    width: min(29rem, 46vw);
    color: rgba(45, 212, 191, 0.42);
    transform: scaleX(-1);
  }

  .signal-wave-c {
    right: 28%;
    bottom: 12%;
    width: min(24rem, 40vw);
    color: rgba(129, 140, 248, 0.34);
  }

  .hero-circuit-lines {
    position: absolute;
    inset: 0;
    opacity: 0.64;
  }

  .trace {
    position: absolute;
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(56, 189, 248, 0.6), transparent);
    transform-origin: left center;
  }

  .trace-a {
    top: 22%;
    left: 6%;
    width: 36%;
  }

  .trace-b {
    right: 4%;
    top: 38%;
    width: 28%;
  }

  .trace-c {
    left: 34%;
    bottom: 18%;
    width: 42%;
  }

  .trace-d {
    right: 18%;
    bottom: 30%;
    width: 18%;
    background: linear-gradient(90deg, transparent, rgba(45, 212, 191, 0.42), transparent);
  }

  .hero-shell {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 3rem;
    align-items: center;
  }

  .hero-copy {
    max-width: 43rem;
  }

  .hero-kicker {
    margin-bottom: 1.25rem;
    color: #38bdf8;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-title {
    margin: 0;
    max-width: 14ch;
    color: #f8fafc;
    font-size: 2.8rem;
    line-height: 0.98;
    font-weight: 850;
    letter-spacing: 0;
  }

  .hero-title span {
    display: inline-block;
    color: transparent;
    background: linear-gradient(135deg, #60a5fa, #22d3ee 48%, #818cf8);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .hero-lead {
    margin: 1.5rem 0 0;
    max-width: 39rem;
    color: #cbd5e1;
    font-size: 1rem;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.82rem 1.1rem;
    border-radius: 0.65rem;
    font-size: 0.94rem;
    font-weight: 750;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      background 0.22s ease,
      border-color 0.22s ease,
      color 0.22s ease;
  }

  .hero-btn-primary {
    color: #ffffff;
    border: 1px solid rgba(56, 189, 248, 0.36);
    background: linear-gradient(135deg, #2563eb, #0891b2);
    box-shadow: 0 16px 34px rgba(14, 165, 233, 0.18);
  }

  .hero-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 44px rgba(14, 165, 233, 0.28);
  }

  .hero-btn-secondary {
    color: #e2e8f0;
    border: 1px solid rgba(148, 163, 184, 0.26);
    background: rgba(15, 23, 42, 0.42);
  }

  .hero-btn-secondary:hover {
    color: #ffffff;
    transform: translateY(-2px);
    border-color: rgba(56, 189, 248, 0.46);
    background: rgba(30, 41, 59, 0.74);
  }

  .hero-btn:focus-visible,
  .hero-social-link:focus-visible,
  .carousel-arrow:focus-visible,
  .carousel-dot:focus-visible {
    outline: 2px solid #38bdf8;
    outline-offset: 3px;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 2rem;
    max-width: 39rem;
  }

  .hero-meta-item {
    padding: 0.85rem;
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 0.75rem;
    background: rgba(15, 23, 42, 0.48);
  }

  .hero-meta-item strong {
    display: block;
    color: #e0f2fe;
    font-size: 0.84rem;
    line-height: 1.2;
  }

  .hero-meta-item span {
    display: block;
    margin-top: 0.35rem;
    color: #94a3b8;
    font-size: 0.76rem;
    line-height: 1.35;
  }

  .hero-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .hero-social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.35rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 999px;
    color: #cbd5e1;
    background: rgba(15, 23, 42, 0.34);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 650;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .hero-social-link:hover {
    color: #ffffff;
    transform: translateY(-2px);
    border-color: rgba(56, 189, 248, 0.34);
    background: rgba(30, 41, 59, 0.72);
  }

  .hero-visual {
    min-width: 0;
  }

  .project-carousel {
    position: relative;
    max-width: 100%;
    overflow: hidden;
    isolation: isolate;
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 1.1rem;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.78), rgba(2, 6, 23, 0.92)),
      #020617;
    box-shadow:
      0 24px 70px rgba(2, 6, 23, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(18px) saturate(1.28);
    -webkit-backdrop-filter: blur(18px) saturate(1.28);
  }

  .project-carousel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.04) 1px, transparent 1px),
      linear-gradient(135deg, rgba(56, 189, 248, 0.08), transparent 38%, rgba(129, 140, 248, 0.06));
    background-size: 24px 24px, 24px 24px, 100% 100%;
    pointer-events: none;
  }

  .carousel-header,
  .carousel-viewport,
  .carousel-controls {
    position: relative;
    z-index: 1;
  }

  .carousel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 1.2rem 0;
  }

  .carousel-header strong {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: #f8fafc;
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
  }

  .carousel-header strong::before {
    content: '';
    width: 0.62rem;
    height: 0.62rem;
    border-radius: 999px;
    background: #38bdf8;
    box-shadow:
      0 0 0 0.34rem rgba(56, 189, 248, 0.12),
      0 0 22px rgba(56, 189, 248, 0.58);
  }

  .carousel-header strong::after {
    content: '';
    width: 4.5rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(56, 189, 248, 0.72), transparent);
  }

  .carousel-viewport {
    overflow: clip;
    contain: paint;
    margin: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 0.9rem;
    background:
      linear-gradient(135deg, rgba(8, 47, 73, 0.2), transparent 44%),
      rgba(2, 6, 23, 0.54);
  }

  .carousel-track {
    display: flex;
    width: 100%;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .project-slide {
    flex: 0 0 100%;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-rows: auto 1fr;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.78), rgba(2, 6, 23, 0.94)),
      #020617;
  }

  .project-art {
    position: relative;
    aspect-ratio: 16 / 9;
    min-height: 0;
    overflow: hidden;
    background:
      linear-gradient(140deg, rgba(14, 165, 233, 0.2), transparent 36%),
      linear-gradient(320deg, rgba(129, 140, 248, 0.22), transparent 42%),
      #020617;
  }

  .project-art.has-project-image {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
    background:
      linear-gradient(135deg, rgba(15, 23, 42, 0.78), rgba(15, 23, 42, 0.42)),
      #020617;
  }

  .project-art-image {
    position: relative;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 0.72rem;
    background: rgba(2, 6, 23, 0.42);
    box-shadow: 0 18px 42px rgba(2, 6, 23, 0.22);
  }

  .project-art::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, transparent 0 18%, rgba(56, 189, 248, 0.12) 18% 18.35%, transparent 18.35% 100%),
      linear-gradient(180deg, transparent 0 34%, rgba(129, 140, 248, 0.14) 34% 34.35%, transparent 34.35% 100%);
    opacity: 0.8;
  }

  .project-art.has-project-image::after {
    display: none;
  }

  .art-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.06) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(circle at 52% 48%, black 0%, transparent 74%);
    -webkit-mask-image: radial-gradient(circle at 52% 48%, black 0%, transparent 74%);
  }

  .project-art-summary {
    position: relative;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.7rem;
    padding: 1.45rem;
    overflow: hidden;
  }

  .project-art-summary::before {
    content: '';
    position: absolute;
    inset: auto 1.2rem 1.2rem auto;
    width: 8.5rem;
    height: 8.5rem;
    border: 1px solid rgba(56, 189, 248, 0.16);
    border-radius: 1.2rem;
    background:
      linear-gradient(90deg, transparent 49%, rgba(56, 189, 248, 0.22) 50%, transparent 51%),
      linear-gradient(0deg, transparent 49%, rgba(52, 211, 153, 0.18) 50%, transparent 51%);
    opacity: 0.55;
    transform: rotate(10deg);
  }

  .project-art-summary::after {
    content: '';
    position: absolute;
    left: 1.45rem;
    right: 1.45rem;
    bottom: 1.25rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(56, 189, 248, 0.48), transparent);
  }

  .project-art-kicker,
  .project-art-summary strong {
    position: relative;
    z-index: 1;
  }

  .project-art-kicker {
    align-self: flex-start;
    color: #7dd3fc;
    font-size: 0.72rem;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-art-summary strong {
    max-width: 20rem;
    color: #f8fafc;
    font-size: clamp(1.35rem, 2.6vw, 1.9rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .art-glow {
    position: absolute;
    display: block;
    border-radius: 1rem;
    filter: blur(10px);
    opacity: 0.42;
    transform: rotate(-18deg);
  }

  .art-glow-a {
    left: -10%;
    top: 10%;
    width: 62%;
    height: 30%;
    background: linear-gradient(90deg, rgba(56, 189, 248, 0.42), rgba(37, 99, 235, 0.08));
  }

  .art-glow-b {
    right: -12%;
    bottom: 4%;
    width: 68%;
    height: 34%;
    background: linear-gradient(90deg, rgba(99, 102, 241, 0.08), rgba(34, 211, 238, 0.36));
  }

  .art-line {
    position: absolute;
    z-index: 1;
    display: block;
    height: 2px;
    border-radius: 999px;
